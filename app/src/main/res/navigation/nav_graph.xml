<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/splash_fragment">

    <fragment
        android:id="@+id/splash_fragment"
        android:name="com.example.trackit.ui.SplashFragment"
        android:label="Splash"
        tools:layout="@layout/fragment_splash">
        <action
            android:id="@+id/action_splash_to_onboarding"
            app:destination="@id/onboarding_fragment"
            app:popUpTo="@id/splash_fragment"
            app:popUpToInclusive="true" />
        <action
            android:id="@+id/action_splash_to_inventory"
            app:destination="@id/inventory_fragment"
            app:popUpTo="@id/splash_fragment"
            app:popUpToInclusive="true" />
    </fragment>

    <fragment
        android:id="@+id/onboarding_fragment"
        android:name="com.example.trackit.ui.OnboardingFragment"
        android:label="Welcome"
        tools:layout="@layout/fragment_onboarding">
        <action
            android:id="@+id/action_onboarding_to_inventory"
            app:destination="@id/inventory_fragment"
            app:popUpTo="@id/onboarding_fragment"
            app:popUpToInclusive="true" />
    </fragment>

    <fragment
        android:id="@+id/inventory_fragment"
        android:name="com.example.trackit.ui.inventory.InventoryFragment"
        android:label="Inventory"
        tools:layout="@layout/fragment_inventory">
        <action
            android:id="@+id/action_inventory_to_addItem"
            app:destination="@id/addItem_fragment" />
        <action
            android:id="@+id/action_inventory_to_locations"
            app:destination="@id/locations_fragment" />
        <action
            android:id="@+id/action_inventory_to_settings"
            app:destination="@id/settings_fragment" />
    </fragment>

    <fragment
        android:id="@+id/addItem_fragment"
        android:name="com.example.trackit.ui.inventory.AddItemFragment"
        android:label="Add Item"
        tools:layout="@layout/fragment_add_item" />

    <fragment
        android:id="@+id/locations_fragment"
        android:name="com.example.trackit.ui.inventory.LocationFragment"
        android:label="Locations" />

    <fragment
        android:id="@+id/settings_fragment"
        android:name="com.example.trackit.ui.SettingsFragment"
        android:label="Settings" />

</navigation>
